#include <windows.h>
#include "../src/resource.h"

// Application manifest (Common Controls v6, DPI awareness, UTF-8 code page).
1 24 "app.manifest"

IDD_MAIN DIALOGEX 0, 0, 300, 252
STYLE DS_CENTER | DS_SETFONT | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX | WS_VISIBLE
CAPTION "whisper_destilado"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    PUSHBUTTON      "REC",          IDC_REC,        30,  12,  80,  28, BS_PUSHBUTTON | WS_TABSTOP
    LTEXT           "00:00",        IDC_TIMER,     120,  20,  50,  14, SS_LEFT
    CONTROL         "",             IDC_LED,        "STATIC", SS_OWNERDRAW | WS_VISIBLE, 30, 46, 14, 14
    LTEXT           "",             IDC_STATUS,     50,  48, 220,  12, SS_LEFT
    LTEXT           "Idioma:",      IDC_LANG_LABEL, 30,  72,  30,  12, SS_LEFT
    COMBOBOX                        IDC_LANG,       65,  70, 120, 100, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    CONTROL         "Mic:",         IDC_MIC_LINK,   "SysLink", WS_TABSTOP | WS_VISIBLE, 30, 90, 240, 14
    EDITTEXT                        IDC_TRANSCRIPT, 30, 110, 240, 100, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Avanzado",     IDC_ADVANCED,  110, 222,  80,  18, BS_PUSHBUTTON | WS_TABSTOP
END

IDD_RESULT DIALOGEX 0, 0, 440, 390
STYLE DS_CENTER | DS_SETFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU | WS_VISIBLE
CAPTION "Transcripcion"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "",                                IDC_RESULT_TIER,          10,  10, 420,  14, SS_LEFT
    LTEXT           "",                                IDC_RESULT_MSG,           10,  28, 420,  30, SS_LEFT
    EDITTEXT                                           IDC_RESULT_TEXT,          10,  64, 420, 180, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_TABSTOP
    LTEXT           "",                                IDC_RESULT_WORST_LABEL,   10, 252, 420,  12, SS_LEFT
    EDITTEXT                                           IDC_RESULT_WORST,         10, 266, 420,  50, ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL
    LTEXT           "",                                IDC_RESULT_INFO,          10, 322, 420,  12, SS_LEFT
    PUSHBUTTON      "Retranscribir con mas calidad",   IDC_RESULT_RETRY_QUALITY, 10, 336, 200,  18, WS_TABSTOP
    PUSHBUTTON      "Cambiar idioma y reintentar",     IDC_RESULT_RETRY_LANG,   215, 336, 200,  18, WS_TABSTOP
    PUSHBUTTON      "Copiar",                          IDC_RESULT_COPY,          10, 362,  50,  18, WS_TABSTOP
    PUSHBUTTON      ".txt",                            IDC_RESULT_SAVE_TXT,      65, 362,  50,  18, WS_TABSTOP
    PUSHBUTTON      ".vtt",                            IDC_RESULT_SAVE_VTT,     120, 362,  50,  18, WS_TABSTOP
    PUSHBUTTON      ".srt",                            IDC_RESULT_SAVE_SRT,     175, 362,  50,  18, WS_TABSTOP
    PUSHBUTTON      "Mas formatos",                    IDC_RESULT_SAVE_MORE,    230, 362,  80,  18, WS_TABSTOP
    DEFPUSHBUTTON   "Cerrar",                          IDC_RESULT_CLOSE,        370, 362,  60,  18, BS_DEFPUSHBUTTON | WS_TABSTOP
END

IDD_MIC_PICKER DIALOGEX 0, 0, 320, 84
STYLE DS_CENTER | DS_SETFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU | WS_VISIBLE
CAPTION "Elegir microfono"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Microfono de entrada:",        -1,            10, 12, 200, 12, SS_LEFT
    COMBOBOX                                        IDC_PICK_MIC,  10, 26, 300, 200, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "Aceptar",                      IDOK,         170, 58,  60, 18, BS_DEFPUSHBUTTON | WS_TABSTOP
    PUSHBUTTON      "Cancelar",                     IDCANCEL,     240, 58,  60, 18, WS_TABSTOP
END

IDD_LANG_PICKER DIALOGEX 0, 0, 280, 80
STYLE DS_CENTER | DS_SETFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU | WS_VISIBLE
CAPTION "Cambiar idioma"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    LTEXT           "Idioma para la nueva transcripcion:",  -1,     10, 12, 200, 12, SS_LEFT
    COMBOBOX                                                 IDC_PICK_LANG, 10, 26, 260, 200, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    DEFPUSHBUTTON   "Aceptar",                              IDOK,           130, 54,  60, 18, BS_DEFPUSHBUTTON | WS_TABSTOP
    PUSHBUTTON      "Cancelar",                             IDCANCEL,       200, 54,  60, 18, WS_TABSTOP
END

IDD_SETTINGS DIALOGEX 0, 0, 460, 440
STYLE DS_CENTER | DS_SETFONT | DS_MODALFRAME | WS_CAPTION | WS_SYSMENU | WS_VISIBLE
CAPTION "Avanzado"
FONT 9, "Segoe UI", 400, 0, 0x0
BEGIN
    // Idioma y traducción
    GROUPBOX        "Idioma y traduccion",                          -1,             8,   4, 444,  60
    LTEXT           "Idioma:",                                      -1,            18,  18,  40,  12
    COMBOBOX                                                        IDC_S_LANG,    62,  16, 200, 220, CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Traducir al ingles",                           IDC_S_TRANSLATE, 270, 18, 120,  12
    AUTOCHECKBOX    "Forzar deteccion de idioma",                   IDC_S_DETECT_LANG, 18, 38, 200, 12
    LTEXT           "Hilos:",                                       -1,           270,  38,  30, 12
    EDITTEXT                                                        IDC_S_THREADS, 305, 36,  40, 14, ES_RIGHT | WS_TABSTOP

    // Estrategia
    GROUPBOX        "Estrategia de muestreo",                       -1,             8,  68, 444,  36
    AUTORADIOBUTTON "Greedy",                                       IDC_S_GREEDY,  18,  84,  60, 12, WS_GROUP | WS_TABSTOP
    AUTORADIOBUTTON "Beam search",                                  IDC_S_BEAM,    80,  84,  80, 12, WS_TABSTOP
    LTEXT           "beam_size:",                                   -1,           170,  84,  50, 12
    EDITTEXT                                                        IDC_S_BEAM_SIZE, 220, 82, 40, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "best_of:",                                     -1,           280,  84,  40, 12
    EDITTEXT                                                        IDC_S_BEST_OF, 320,  82,  40, 14, ES_RIGHT | WS_TABSTOP

    // Tunables del decoder
    GROUPBOX        "Tunables del decoder",                         -1,             8, 108, 444,  60
    LTEXT           "temperature:",                                 -1,            18, 122,  60, 12
    EDITTEXT                                                        IDC_S_TEMP,    80, 120,  50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "temperature_inc:",                             -1,           140, 122,  70, 12
    EDITTEXT                                                        IDC_S_TEMP_INC, 215, 120, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "length_penalty:",                              -1,           275, 122,  70, 12
    EDITTEXT                                                        IDC_S_LEN_PENALTY, 345, 120, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "entropy_thold:",                               -1,            18, 142,  70, 12
    EDITTEXT                                                        IDC_S_ENTROPY, 90, 140,  50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "logprob_thold:",                               -1,           150, 142,  70, 12
    EDITTEXT                                                        IDC_S_LOGPROB, 220, 140, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "no_speech_thold:",                             -1,           280, 142,  70, 12
    EDITTEXT                                                        IDC_S_NO_SPEECH, 350, 140, 50, 14, ES_RIGHT | WS_TABSTOP

    // Tokens y contexto
    GROUPBOX        "Tokens y contexto",                            -1,             8, 172, 444,  44
    LTEXT           "n_max_text_ctx:",                              -1,            18, 186,  70, 12
    EDITTEXT                                                        IDC_S_N_MAX_TEXT, 90, 184, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "max_len:",                                     -1,           150, 186,  40, 12
    EDITTEXT                                                        IDC_S_MAX_LEN, 195, 184, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "max_tokens:",                                  -1,           255, 186,  60, 12
    EDITTEXT                                                        IDC_S_MAX_TOKENS, 320, 184, 50, 14, ES_RIGHT | WS_TABSTOP
    LTEXT           "audio_ctx (0 = default del modelo):",          -1,            18, 204, 180, 12
    EDITTEXT                                                        IDC_S_AUDIO_CTX, 200, 202, 50, 14, ES_RIGHT | WS_TABSTOP

    // Prompt
    GROUPBOX        "Prompt inicial",                               -1,             8, 220, 444,  74
    EDITTEXT                                                        IDC_S_PROMPT,  18, 234, 432,  34, ES_MULTILINE | ES_AUTOVSCROLL | WS_VSCROLL | WS_TABSTOP
    AUTOCHECKBOX    "Repetir el prompt en cada ventana (carry_initial_prompt)", IDC_S_CARRY_PROMPT, 18, 274, 400, 12

    // Comportamiento
    GROUPBOX        "Comportamiento",                               -1,             8, 298, 444,  52
    AUTOCHECKBOX    "suppress_blank",                               IDC_S_SUPPRESS_BLANK, 18, 312, 100, 12
    AUTOCHECKBOX    "suppress_nst (no-speech tokens)",              IDC_S_SUPPRESS_NST,  150, 312, 200, 12
    AUTOCHECKBOX    "single_segment",                               IDC_S_SINGLE_SEG, 18, 329, 100, 12
    AUTOCHECKBOX    "split_on_word",                                IDC_S_SPLIT_WORD, 150, 329, 100, 12
    AUTOCHECKBOX    "tdrz_enable (tinydiarize)",                    IDC_S_TDRZ, 280, 329, 150, 12

    // Debug
    GROUPBOX        "Debug",                                        -1,             8, 354, 444,  32
    AUTOCHECKBOX    "print_progress",                               IDC_S_PRINT_PROGRESS, 18, 368, 120, 12
    AUTOCHECKBOX    "print_realtime",                               IDC_S_PRINT_REALTIME, 150, 368, 120, 12

    // Botones
    PUSHBUTTON      "Restaurar defaults",                           IDC_S_RESTORE, 10, 412, 120, 18, WS_TABSTOP
    DEFPUSHBUTTON   "Aceptar",                                      IDOK,         290, 412,  70, 18, BS_DEFPUSHBUTTON | WS_TABSTOP
    PUSHBUTTON      "Cancelar",                                     IDCANCEL,     370, 412,  80, 18, WS_TABSTOP
END

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 0,1,0,0
 PRODUCTVERSION 0,1,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "whisper_destilado"
            VALUE "FileDescription", "Whisper RAM-only transcriber"
            VALUE "FileVersion", "0.1.0.0"
            VALUE "InternalName", "whisper_destilado"
            VALUE "OriginalFilename", "whisper_destilado.exe"
            VALUE "ProductName", "whisper_destilado"
            VALUE "ProductVersion", "0.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
